# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name
DB_PORT=your_db_port

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=starttls
MAIL_TIMEOUT=20
MAIL_DEBUG=false
MAIL_DEBUG_LEVEL=2
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_16_digit_app_password
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Your App Name
MAIL_REPLY_TO=your_email@gmail.com
MAIL_REPLY_TO_NAME=Your Support Team

# ============================================
# EMAIL CONFIGURATION (Resend API - optional)
# If RESEND_API_KEY is defined, app will use Resend instead of SMTP.
# ============================================
RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=
RESEND_TIMEOUT=20

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/your_path
